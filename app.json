{
  "expo": {
    "name": "ScienceFit",
    "slug": "sciencefit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#D32F2F",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sciencefit.app"
    },
    "android": {
      "package": "com.sciencefit.app",
      "backgroundColor": "#D32F2F"
    },
    "web": {
      "bundler": "metro"
    }
  }
}